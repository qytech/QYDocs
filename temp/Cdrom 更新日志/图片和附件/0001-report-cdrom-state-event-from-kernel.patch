 mode change 100644 => 100755 include/linux/cdrom.h

diff --git a/drivers/cdrom/cdrom.c b/drivers/cdrom/cdrom.c
old mode 100644
new mode 100755
index d3947388a3ef..4aeb6cd277d8
--- a/drivers/cdrom/cdrom.c
+++ b/drivers/cdrom/cdrom.c
@@ -283,6 +283,8 @@
 #include <linux/blkdev.h>
 #include <linux/times.h>
 #include <linux/uaccess.h>
+#include <linux/kobject.h>
+#include <linux/workqueue.h>
 #include <scsi/scsi_common.h>
 #include <scsi/scsi_request.h>
 
@@ -586,6 +588,250 @@ static int cdrom_mrw_set_lba_space(struct cdrom_device_info *cdi, int space)
 	return 0;
 }
 
+/* Polling intervals for tray/disc state monitoring (milliseconds).
+ * When the drive supports async (interrupt-driven) media-change events we
+ * only poll infrequently as a safety net; otherwise we rely on polling. */
+#define CDROM_STATE_POLL_MSECS		2000
+#define CDROM_STATE_POLL_ASYNC_MSECS	30000
+
+/*
+ * After a tray-close, report closed/absent immediately, then keep polling at
+ * a faster rate to catch the disc spinning up.  Only report closed/present
+ * after DISC_OK has been seen consistently for DISC_OK_COUNT polls, avoiding
+ * a false present from a transient spin-up glitch.
+ *
+ * STABILIZE_POLL_MSECS : fast poll interval while waiting for disc spin-up
+ * DISC_OK_COUNT        : consecutive DISC_OK readings required before
+ *                        reporting present
+ */
+#define CDROM_TRAY_OPEN_POLL_MSECS	200	/* fast poll while tray open to catch close quickly */
+#define CDROM_STABILIZE_POLL_MSECS	500
+#define CDROM_DISC_OK_COUNT		10	/* 10 × 500 ms = 5 s confirmation for normal disc */
+#define CDROM_CLOSING_TIMEOUT_MS	10000	/* 10 s wall-clock timeout for slow disc spin-up */
+
+/*
+ * CDROM_ACTION values and their meaning for the application:
+ *
+ *   tray_opening  - tray is moving out (play open animation)
+ *   tray_closing  - tray just closed, no disc confirmed yet (play close
+ *                   animation; may be followed by disc_ready)
+ *   disc_ready    - disc has spun up and is readable (show ready state)
+ *   disc_removed  - disc removed while tray was closed (show empty state)
+ *   initial_open  - boot-time initial state: tray open
+ *   initial_empty    - boot-time initial state: closed, no disc
+ *   initial_ready    - boot-time initial state: closed, disc present
+ *   tray_closed_empty - closing window timed out with no disc confirmed;
+ *                       application should end the closing animation
+ */
+static void cdrom_send_state_uevent(struct cdrom_device_info *cdi,
+				    int state, int prev_state)
+{
+	struct kobject *kobj;
+	char *envp[4];
+	char tray_env[32];
+	char disc_env[32];
+	char action_env[48];
+
+	if (!cdi->disk)
+		return;
+
+	kobj = &disk_to_dev(cdi->disk)->kobj;
+
+	switch (state) {
+	case CDS_TRAY_OPEN:
+		snprintf(tray_env,   sizeof(tray_env),   "CDROM_TRAY=open");
+		snprintf(disc_env,   sizeof(disc_env),   "CDROM_DISC=unknown");
+		snprintf(action_env, sizeof(action_env),
+			 prev_state == -1 ? "CDROM_ACTION=initial_open"
+					  : "CDROM_ACTION=tray_opening");
+		break;
+	case CDS_NO_DISC:
+		snprintf(tray_env,   sizeof(tray_env),   "CDROM_TRAY=closed");
+		snprintf(disc_env,   sizeof(disc_env),   "CDROM_DISC=absent");
+		snprintf(action_env, sizeof(action_env),
+			 prev_state == -1        ? "CDROM_ACTION=initial_empty" :
+			 prev_state == CDS_TRAY_OPEN ? "CDROM_ACTION=tray_closing"
+						     : "CDROM_ACTION=disc_removed");
+		break;
+	case CDS_DISC_OK:
+		snprintf(tray_env,   sizeof(tray_env),   "CDROM_TRAY=closed");
+		snprintf(disc_env,   sizeof(disc_env),   "CDROM_DISC=present");
+		snprintf(action_env, sizeof(action_env),
+			 prev_state == -1 ? "CDROM_ACTION=initial_ready"
+					  : "CDROM_ACTION=disc_ready");
+		break;
+	default:
+		return;
+	}
+
+	envp[0] = tray_env;
+	envp[1] = disc_env;
+	envp[2] = action_env;
+	envp[3] = NULL;
+
+	kobject_uevent_env(kobj, KOBJ_CHANGE, envp);
+	cd_dbg(CD_OPEN, "%s: tray uevent: %s %s %s\n",
+	       cdi->name, tray_env, disc_env, action_env);
+}
+
+/* Return true if the drive reports async (interrupt-driven) media events. */
+static bool cdrom_has_async_events(struct cdrom_device_info *cdi)
+{
+	return cdi->disk &&
+	       (cdi->disk->async_events & DISK_EVENT_MEDIA_CHANGE);
+}
+
+static void cdrom_send_closing_timeout_uevent(struct cdrom_device_info *cdi)
+{
+	char *envp[4];
+	struct kobject *kobj;
+
+	if (!cdi->disk)
+		return;
+
+	kobj = &disk_to_dev(cdi->disk)->kobj;
+	envp[0] = "CDROM_TRAY=closed";
+	envp[1] = "CDROM_DISC=absent";
+	envp[2] = "CDROM_ACTION=tray_closed_empty";
+	envp[3] = NULL;
+
+	kobject_uevent_env(kobj, KOBJ_CHANGE, envp);
+	cd_dbg(CD_OPEN, "%s: tray closed empty (timeout)\n", cdi->name);
+}
+
+/*
+ * Query drive_status and manage the stabilization state machine.
+ *
+ * Returns the interval (jiffies) to use for the next poll.  The caller must
+ * reschedule state_work with the returned value.
+ *
+ * State machine:
+ *
+ *  Any state
+ *    → TRAY_OPEN : send open uevent immediately, reset disc_ok_count
+ *
+ *  TRAY_OPEN → NO_DISC (tray just closed)
+ *    Send closed/absent immediately so the application knows the tray has
+ *    shut.  Then switch to fast polling to catch disc spin-up.
+ *
+ *  Waiting for disc (last_tray_state == NO_DISC, disc_ok_count >= 0)
+ *    NO_DISC  : no change, keep fast-polling
+ *    DISC_OK  : increment disc_ok_count; once it reaches CDROM_DISC_OK_COUNT
+ *               send closed/present and return to normal poll rate
+ *
+ *  DISC_OK (disc present and stable)
+ *    NO_DISC  : disc removed; send absent immediately, reset disc_ok_count,
+ *               switch back to fast-poll window
+ */
+static unsigned long cdrom_state_check_and_notify(struct cdrom_device_info *cdi)
+{
+	int state;
+
+	if (!CDROM_CAN(CDC_DRIVE_STATUS))
+		goto normal_interval;
+
+	state = cdi->ops->drive_status(cdi, CDSL_CURRENT);
+	if (state != CDS_TRAY_OPEN && state != CDS_DISC_OK)
+		state = CDS_NO_DISC;
+
+	/* Tray opened — report immediately; reset all close-cycle state.
+	 * Keep polling at a fast rate so we detect the tray closing quickly. */
+	if (state == CDS_TRAY_OPEN) {
+		cdi->disc_ok_count = 0;
+		cdi->closing_deadline = ns_to_ktime(0);
+		cdi->empty_reported = false;
+		if (state != cdi->last_tray_state) {
+			int prev = cdi->last_tray_state;
+			cdi->last_tray_state = state;
+			cdrom_send_state_uevent(cdi, state, prev);
+		}
+		return msecs_to_jiffies(CDROM_TRAY_OPEN_POLL_MSECS);
+	}
+
+	if (state == CDS_NO_DISC) {
+		if (cdi->last_tray_state == CDS_TRAY_OPEN) {
+			/*
+			 * Tray just closed: report closed/absent immediately,
+			 * record a wall-clock deadline for disc spin-up detection,
+			 * then fast-poll.  The deadline is checked on each poll so
+			 * that spurious calls (e.g. from cdrom_check_events on a
+			 * DISK_MEDIA_CHANGE interrupt) cannot advance it.
+			 */
+			int prev = cdi->last_tray_state;
+			cdi->disc_ok_count = 0;
+			cdi->empty_reported = false;
+			cdi->closing_deadline = ktime_add_ms(ktime_get(),
+						CDROM_CLOSING_TIMEOUT_MS);
+			cdi->last_tray_state = CDS_NO_DISC;
+			cdrom_send_state_uevent(cdi, CDS_NO_DISC, prev);
+			return msecs_to_jiffies(CDROM_STABILIZE_POLL_MSECS);
+		}
+
+		if (cdi->last_tray_state == CDS_NO_DISC) {
+			cdi->disc_ok_count = 0;
+			/* tray_closed_empty already sent — don't repeat it. */
+			if (cdi->empty_reported)
+				goto normal_interval;
+			if (ktime_to_ns(cdi->closing_deadline)) {
+				if (ktime_after(ktime_get(), cdi->closing_deadline)) {
+					/* Deadline passed with no disc: confirm empty. */
+					cdi->closing_deadline = ns_to_ktime(0);
+					cdi->empty_reported = true;
+					cdrom_send_closing_timeout_uevent(cdi);
+					goto normal_interval;
+				}
+				return msecs_to_jiffies(CDROM_STABILIZE_POLL_MSECS);
+			}
+			goto normal_interval;
+		}
+
+		/* Disc was present, now gone (disc removed mid-session). */
+		{
+			int prev = cdi->last_tray_state;
+			cdi->disc_ok_count = 0;
+			cdi->closing_deadline = ns_to_ktime(0);
+			cdi->empty_reported = false;
+			cdi->last_tray_state = CDS_NO_DISC;
+			cdrom_send_state_uevent(cdi, CDS_NO_DISC, prev);
+		}
+		return msecs_to_jiffies(CDROM_STABILIZE_POLL_MSECS);
+	}
+
+	/*
+	 * state == CDS_DISC_OK: accumulate stable readings.
+	 * Do NOT gate on empty_reported: a slow disc may spin up after
+	 * tray_closed_empty has already fired.  The app will receive
+	 * tray_closed_empty then disc_ready in sequence, which is correct.
+	 */
+	cdi->disc_ok_count++;
+	if (cdi->disc_ok_count < CDROM_DISC_OK_COUNT)
+		return msecs_to_jiffies(CDROM_STABILIZE_POLL_MSECS);
+
+	/* Disc confirmed stable — report present and resume normal rate. */
+	if (cdi->last_tray_state != CDS_DISC_OK) {
+		int prev = cdi->last_tray_state;
+		cdi->last_tray_state = CDS_DISC_OK;
+		cdi->empty_reported = false;
+		cdrom_send_state_uevent(cdi, CDS_DISC_OK, prev);
+	}
+	cdi->disc_ok_count = 0;
+	cdi->closing_deadline = ns_to_ktime(0);
+
+normal_interval:
+	if (cdrom_has_async_events(cdi))
+		return msecs_to_jiffies(CDROM_STATE_POLL_ASYNC_MSECS);
+	return msecs_to_jiffies(CDROM_STATE_POLL_MSECS);
+}
+
+static void cdrom_state_work_fn(struct work_struct *work)
+{
+	struct cdrom_device_info *cdi =
+		container_of(work, struct cdrom_device_info, state_work.work);
+
+	schedule_delayed_work(&cdi->state_work,
+			      cdrom_state_check_and_notify(cdi));
+}
+
 int register_cdrom(struct cdrom_device_info *cdi)
 {
 	static char banner_printed;
@@ -637,6 +883,18 @@ int register_cdrom(struct cdrom_device_info *cdi)
 	mutex_lock(&cdrom_mutex);
 	list_add(&cdi->list, &cdrom_list);
 	mutex_unlock(&cdrom_mutex);
+
+	/* Start tray/disc state monitoring; delay=0 fires immediately for
+	 * initial-state uevent on boot. */
+	if (CDROM_CAN(CDC_DRIVE_STATUS)) {
+		cdi->last_tray_state = -1;
+		cdi->disc_ok_count = 0;
+		cdi->closing_deadline = ns_to_ktime(0);
+		cdi->empty_reported = false;
+		INIT_DELAYED_WORK(&cdi->state_work, cdrom_state_work_fn);
+		schedule_delayed_work(&cdi->state_work, 0);
+	}
+
 	return 0;
 }
 #undef ENSURE
@@ -645,6 +903,9 @@ void unregister_cdrom(struct cdrom_device_info *cdi)
 {
 	cd_dbg(CD_OPEN, "entering unregister_cdrom\n");
 
+	if (CDROM_CAN(CDC_DRIVE_STATUS))
+		cancel_delayed_work_sync(&cdi->state_work);
+
 	mutex_lock(&cdrom_mutex);
 	list_del(&cdi->list);
 	mutex_unlock(&cdrom_mutex);
@@ -1493,6 +1754,24 @@ unsigned int cdrom_check_events(struct cdrom_device_info *cdi,
 	cdrom_update_events(cdi, clearing);
 	events = cdi->vfs_events;
 	cdi->vfs_events = 0;
+
+	/*
+	 * If the block layer signalled a media-change event (which may have
+	 * been triggered by a hardware interrupt on async-capable drives),
+	 * immediately query the drive status and send a granular uevent.
+	 * This gives sub-millisecond latency on interrupt-driven hardware
+	 * without waiting for the next polling cycle.
+	 */
+	if (events & DISK_EVENT_MEDIA_CHANGE) {
+		unsigned long next = cdrom_state_check_and_notify(cdi);
+		/*
+		 * An async media-change interrupt just fired: reschedule the
+		 * polling work with the interval returned by the state machine
+		 * (may be a fast stabilization interval or the normal rate).
+		 */
+		mod_delayed_work(system_wq, &cdi->state_work, next);
+	}
+
 	return events;
 }
 EXPORT_SYMBOL(cdrom_check_events);
diff --git a/include/linux/cdrom.h b/include/linux/cdrom.h
old mode 100644
new mode 100755
index 528271c60018..6ed7393d6490
--- a/include/linux/cdrom.h
+++ b/include/linux/cdrom.h
@@ -13,6 +13,8 @@
 
 #include <linux/fs.h>		/* not really needed, later.. */
 #include <linux/list.h>
+#include <linux/workqueue.h>
+#include <linux/ktime.h>
 #include <scsi/scsi_common.h>
 #include <uapi/linux/cdrom.h>
 
@@ -64,6 +66,12 @@ struct cdrom_device_info {
 	int for_data;
 	int (*exit)(struct cdrom_device_info *);
 	int mrw_mode_page;
+/* tray/disc state monitoring */
+	int last_tray_state;		/* last reported state: CDS_TRAY_OPEN / CDS_NO_DISC / CDS_DISC_OK / -1 */
+	int disc_ok_count;		/* consecutive DISC_OK readings; send present only after threshold */
+	ktime_t closing_deadline;	/* wall-clock deadline for disc spin-up; 0 = not in closing window */
+	bool empty_reported;		/* true after tray_closed_empty sent; prevents duplicate empty events */
+	struct delayed_work state_work;	/* periodic drive status polling */
 };
 
 struct cdrom_device_ops {
